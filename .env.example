# Prefer `pnpm onboard` (interactive wizard, validates against Linear, writes
# this file). This template is for manual editing / reference.
LINEAR_API_KEY=            # personal API key: Linear > Settings > Account > Security & Access
# LINEAR_TEAM_NAME=Engineering
# DEPLOY_STATE_NAME=In Progress         # entering this state deploys a new session (legacy: TRIGGER_STATE_NAME)
# REVIEW_STATE_NAME=In Review           # entering this state flags the session ready to test (a tmux glyph)
# HEARTBEAT_INTERVAL_MINUTES=3          # how often the central loop checks the board (legacy: POLL_INTERVAL_MINUTES)
# CODEBASE_PATH=/home/ymbo/Work/gemini   # absolute path; git pull --rebase origin main every poll; also the repo gh reads for the review step

# --- Session models (Claude Code model alias or id) ---
# PLAN_MODEL=opus                         # model the planning session runs on
# IMPL_MODEL=sonnet                       # model the implementation subagents run on

# --- Autonomous claim step ---
# AUTO_CLAIM=true                         # set to "false" to disable auto-claiming (on by default; legacy: AUTO_PICK)
# TODO_STATE_NAME=Todo                    # the "ready to work" state the claim step draws from
# RISK_LABELS=migration,infra,security,breaking   # labels that are never auto-claimed (left for manual start)
# MAX_IN_PROGRESS=3                       # WIP cap: stop claiming once this many are In Progress (1 = one at a time)

# --- Cleanup step ---
# AUTO_CLEANUP=true                       # set to "false" to disable; when on, a worktree + session is torn down once its PR merges
# SESSION_TEARDOWN_HOOK=                  # optional script run by end-session.sh before removing a worktree (stop containers, free ports); receives "<worktree_path> <name>"

# The review step (addressing comments on your open PRs) and the cleanup step
# (removing merged PRs' worktrees) have no other settings: both run every
# heartbeat against the repo gh resolves from CODEBASE_PATH, and need `gh`
# installed and authenticated.

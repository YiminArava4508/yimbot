# Prefer `pnpm onboard` (interactive wizard, validates against Linear, writes
# this file). This template is for manual editing / reference.
LINEAR_API_KEY=            # personal API key: Linear > Settings > Account > Security & Access
# LINEAR_TEAM_NAME=Engineering
# TRIGGER_STATE_NAME=In Progress
# REVIEW_STATE_NAME=In Review           # entering this state resumes an existing worktree's dev env
# POLL_INTERVAL_MINUTES=3
# CODEBASE_PATH=/home/ymbo/Work/gemini   # absolute path; git pull --rebase origin main every poll
# RESUME_ON_REVIEW=false                  # off by default; set true to spin up the local dev env when a ticket enters review

# --- Autonomous ticket picker ---
# AUTO_PICK=true                          # set to "false" to disable auto-picking (on by default)
# MAX_REVIEW=3                            # stall picking when this many of your tickets are In Review
# TODO_STATE_NAME=Todo                    # the "ready to work" state the picker draws from
# RISK_LABELS=migration,infra,security,breaking   # labels that are never auto-picked (left for manual start)
